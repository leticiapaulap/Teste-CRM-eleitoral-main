{
  "rewrites": [
    {
      "source": "/cadastro",
      "destination": "/index.html"
    },
    {
      "source": "/api/siv",
      "destination": "/api?route=siv"
    },
    {
      "source": "/api/auth/:path*",
      "destination": "/api?route=auth/:path*"
    },
    {
      "source": "/api/upload/:path*",
      "destination": "/api?route=upload/:path*"
    },
    {
      "source": "/api/leaders/:path*",
      "destination": "/api?route=leaders/:path*"
    },
    {
      "source": "/api/admin/:path*",
      "destination": "/api?route=admin/:path*"
    },
    {
      "source": "/api/map/:path*",
      "destination": "/api?route=map/:path*"
    },
    {
      "source": "/api/contact/:path*",
      "destination": "/api?route=contact/:path*"
    }
  ]
}
